cabal-version:      3.0
-- The cabal-version field refers to the version of the .cabal specification,
-- and can be different from the cabal-install (the tool) version and the
-- Cabal (the library) version you are using. As such, the Cabal (the library)
-- version used must be equal or greater than the version stated in this field.
-- Starting from the specification version 2.2, the cabal-version field must be
-- the first thing in the cabal file.

-- Initial package description 'hello-haskell1' generated by
-- 'cabal init'. For further documentation, see:
--   http://haskell.org/cabal/users-guide/
--
-- The name of the package.
name:               llm-chat

-- The package version.
-- See the Haskell package versioning policy (PVP) for standards
-- guiding when and how versions should be incremented.
-- https://pvp.haskell.org
-- PVP summary:     +-+------- breaking API changes
--                  | | +----- non-breaking API additions
--                  | | | +--- code changes with no API change
version:            0.1.0.0

-- A short (one-line) description of the package.
-- synopsis:

-- A longer description of the package.
-- description:

-- The license under which the package is released.
license:            BSD-3-Clause

-- The file containing the license text.
license-file:       LICENSE

-- The package author(s).
author:             Daniel van den Eijkel

-- An email address to which users can send suggestions, bug reports, and patches.
maintainer:         1515314+aische@users.noreply.github.com

-- A copyright notice.
-- copyright:
category:           unknown
build-type:         Simple

-- Extra doc files to be distributed with the package, such as a CHANGELOG or a README.
extra-doc-files:    CHANGELOG.md

-- Extra source files to be distributed with the package, such as examples, or a tutorial module.
-- extra-source-files:

common opts
    default-language: GHC2021
    default-extensions:
        ConstraintKinds
        DataKinds
        DeriveAnyClass
        DerivingStrategies
        DerivingVia
        LambdaCase
        OverloadedStrings
    ghc-options: 
        -Wall 
        -Wunused-imports
        -Werror=missing-fields

library
    import: opts
    exposed-modules:
        LLM
        LLM.Core.Abort
        LLM.Generate.Chat
        LLM.Generate.ChatStep
        LLM.Generate.ChatStepInterpreter
        LLM.Generate.Common
        LLM.Generate.Generate
        LLM.Generate.Types
        LLM.Generate.Utils
        LLM.Generate.WithFallback
        LLM.Core.Types
        LLM.Core.LLMProvider
        LLM.Load.LoadEnvs
        LLM.Load.LoadGateways
        LLM.Load.LoadModels
        LLM.Load.LoadTools
        LLM.Load.LoadWorkers
        LLM.Load.Types
        LLM.Providers.Gemini
        LLM.Providers.Claude
        LLM.Providers.OpenAI
        LLM.Providers.Ollama
        LLM.Core.Logger
        LLM.Core.Usage
        LLM.Core.Utils
        LLM.Core.ProviderUtils
        LLM.Tools.Weather
        LLM.Tools.Age
        LLM.Tools.History
        LLM.Tools.Readfile
        LLM.Tools.Writefile
        LLM.Tools.ReplaceInFile
        LLM.Tools.Worker
        LLM.Tools.Readdir
        LLM.Tools.FsConfig
    other-modules:
        LLM.Core.SSE
    hs-source-dirs:     src
    build-depends:
        autodocodec    >=0.5 && < 0.6,
        autodocodec-schema >=0.2 && <0.3,
        base           ^>=4.18,
        containers     ^>=0.6.7,
        lens           >=5.3 && <5.4,
        mtl            >=2.3   && <2.4,
        text           >=1.2   && <2.2,
        aeson          >=2.0   && <2.3,
        aeson-pretty   >=0.8   && <0.9,

        bytestring     >=0.11  && <0.12,
        directory      >=1.3   && <1.4,
        filepath       >=1.4   && <1.6,
        http-client    >=0.7   && <0.8,
        http-types     >=0.12  && <0.13,
        req            >=3.13.4 && <3.14,
        retry          >=0.9   && <0.10,
        time           >=1.11  && <1.15,
        unordered-containers >=0.2 && < 0.3,
        vector         >=0.13,

executable llm-chat
    import: opts
    main-is:          Main.hs
    other-modules:    Adapters.Repl,
                      Adapters.SessionChat,
                      Adapters.StreamChatLoop,
                      Example1,
                      Example2,
                      Example3,
                      Example4,
                      Example5,
                      RecordTestConversation
    hs-source-dirs:   app
    build-depends:
        autodocodec    >=0.5 && < 0.6,
        autodocodec-schema >=0.2 && <0.3,
        base           ^>=4.18,
        text           >=1.2   && <2.2,
        containers     ^>=0.6.7,
        aeson          >=2.0   && <2.3,
        bytestring     >=0.11 && <0.12,
        directory      >=1.3   && <1.4,
        filepath       >=1.4   && <1.6,
        llm-chat,
        dotenv         >=0.9   && <0.13,
        optparse-applicative >= 0.16 && <0.19,
        retry          >=0.9   && <0.10

test-suite llm-chat-test
    import: opts
    type:               exitcode-stdio-1.0
    main-is:            Spec.hs
    other-modules:      LLM.ClaudeSpec
                        LLM.GeminiSpec
                        LLM.GenericConversationTest
                        LLM.RecordedConversationSpec
                        LLM.OpenAISpec
                        LLM.TypesSpec
                        LLM.ChatSpec
                        LLM.TestKit
    hs-source-dirs:     test
    build-depends:
        base           ^>=4.18,
        containers ^>=0.6.7,
        text           >=1.2   && <2.2,
        aeson          >=2.0   && <2.3,
        hspec          >=2.10  && <2.12,
        llm-chat,
        retry          >=0.9   && <0.10
    build-tool-depends: hspec-discover:hspec-discover